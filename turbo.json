{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "@hivecfm/cache#build": {
      "dependsOn": ["@hivecfm/logger#build"]
    },
    "@hivecfm/cache#go": {
      "dependsOn": ["@hivecfm/logger#build"]
    },
    "@hivecfm/cache#lint": {
      "dependsOn": ["@hivecfm/logger#build"]
    },
    "@hivecfm/cache#test": {
      "dependsOn": ["@hivecfm/logger#build"]
    },
    "@hivecfm/cache#test:coverage": {
      "dependsOn": ["@hivecfm/logger#build"]
    },
    "@hivecfm/database#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@hivecfm/database#lint": {
      "dependsOn": ["@hivecfm/logger#build", "@hivecfm/database#build"]
    },
    "@hivecfm/database#setup": {
      "dependsOn": ["db:up"]
    },
    "@hivecfm/i18n-utils#build": {
      "dependsOn": ["^build"],
      "outputs": ["packages/i18n-utils/dist/**"]
    },
    "@hivecfm/i18n-utils#lint": {
      "dependsOn": ["^lint"]
    },
    "@hivecfm/i18n-utils#test": {
      "dependsOn": ["@hivecfm/i18n-utils#build"]
    },
    "@hivecfm/js-core#build": {
      "dependsOn": ["^build", "@hivecfm/database#build"],
      "outputs": ["dist/**"]
    },
    "@hivecfm/js-core#go": {
      "cache": false,
      "dependsOn": ["@hivecfm/database#db:setup"],
      "persistent": true
    },
    "@hivecfm/js-core#lint": {
      "dependsOn": ["@hivecfm/database#build"]
    },
    "@hivecfm/react-native#build": {
      "dependsOn": ["^build", "@hivecfm/database#build"],
      "outputs": ["dist/**"]
    },
    "@hivecfm/react-native#go": {
      "cache": false,
      "dependsOn": ["@hivecfm/database#db:setup"],
      "persistent": true
    },
    "@hivecfm/storage#build": {
      "dependsOn": ["@hivecfm/logger#build"]
    },
    "@hivecfm/storage#go": {
      "cache": false,
      "dependsOn": ["@hivecfm/storage#build"],
      "persistent": true
    },
    "@hivecfm/storage#lint": {
      "dependsOn": ["@hivecfm/logger#build"]
    },
    "@hivecfm/storage#test": {
      "dependsOn": ["@hivecfm/logger#build"]
    },
    "@hivecfm/storage#test:coverage": {
      "dependsOn": ["@hivecfm/logger#build"]
    },
    "@hivecfm/survey-ui#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@hivecfm/survey-ui#build:dev": {
      "dependsOn": ["^build:dev"],
      "outputs": ["dist/**"]
    },
    "@hivecfm/survey-ui#go": {
      "cache": false,
      "dependsOn": ["@hivecfm/survey-ui#build"],
      "persistent": true
    },
    "@hivecfm/surveys#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@hivecfm/surveys#build:dev": {
      "dependsOn": ["^build:dev", "@hivecfm/i18n-utils#build"],
      "outputs": ["dist/**"]
    },
    "@hivecfm/surveys#go": {
      "cache": false,
      "dependsOn": ["@hivecfm/surveys#build"],
      "persistent": true
    },
    "@hivecfm/surveys#test": {
      "dependsOn": ["@hivecfm/survey-ui#build"]
    },
    "@hivecfm/surveys#test:coverage": {
      "dependsOn": ["@hivecfm/survey-ui#build"]
    },
    "@hivecfm/ui#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@hivecfm/ui#build:dev": {
      "dependsOn": ["^build:dev"],
      "outputs": ["dist/**"]
    },
    "@hivecfm/ui#go": {
      "cache": false,
      "dependsOn": ["@hivecfm/ui#build"],
      "persistent": true
    },
    "@hivecfm/web#go": {
      "cache": false,
      "dependsOn": ["@hivecfm/database#db:setup"],
      "persistent": true
    },
    "@hivecfm/web#test": {
      "dependsOn": [
        "@hivecfm/logger#build",
        "@hivecfm/database#build",
        "@hivecfm/storage#build",
        "@hivecfm/cache#build"
      ]
    },
    "@hivecfm/web#test:coverage": {
      "dependsOn": [
        "@hivecfm/logger#build",
        "@hivecfm/database#build",
        "@hivecfm/storage#build",
        "@hivecfm/cache#build"
      ]
    },
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "AUDIT_LOG_ENABLED",
        "AUDIT_LOG_GET_USER_IP",
        "AIRTABLE_CLIENT_ID",
        "ASSET_PREFIX_URL",
        "AZUREAD_CLIENT_ID",
        "AZUREAD_CLIENT_SECRET",
        "AZUREAD_TENANT_ID",
        "AUTH_SSO_DEFAULT_TEAM_ID",
        "AUTH_SKIP_INVITE_FOR_SSO",
        "BASE_PATH",
        "BREVO_API_KEY",
        "BREVO_LIST_ID",
        "CRON_SECRET",
        "DATABASE_URL",
        "DEBUG",
        "E2E_TESTING",
        "EMAIL_AUTH_DISABLED",
        "EMAIL_VERIFICATION_DISABLED",
        "ENCRYPTION_KEY",
        "ENTERPRISE_LICENSE_KEY",
        "ENVIRONMENT",
        "GITHUB_ID",
        "GITHUB_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "GOOGLE_SHEETS_CLIENT_ID",
        "GOOGLE_SHEETS_CLIENT_SECRET",
        "GOOGLE_SHEETS_REDIRECT_URL",
        "NOTION_OAUTH_CLIENT_ID",
        "NOTION_OAUTH_CLIENT_SECRET",
        "HEROKU_APP_NAME",
        "HTTP_PROXY",
        "HTTPS_PROXY",
        "IMPRINT_URL",
        "IMPRINT_ADDRESS",
        "INVITE_DISABLED",
        "IS_FORMBRICKS_CLOUD",
        "CHATWOOT_WEBSITE_TOKEN",
        "CHATWOOT_BASE_URL",
        "LOG_LEVEL",
        "NOVU_API_KEY",
        "NOVU_API_URL",
        "HIVECFM_HUB_URL",
        "HIVECFM_HUB_API_KEY",
        "HIVECFM_LICENSE_PUBLIC_KEY",
        "HIVECFM_OFFLINE_LICENSE_TOKEN",
        "MAIL_FROM",
        "MAIL_FROM_NAME",
        "NEXT_PUBLIC_LAYER_API_KEY",
        "NEXT_PUBLIC_DOCSEARCH_APP_ID",
        "NEXT_PUBLIC_DOCSEARCH_API_KEY",
        "NEXT_PUBLIC_DOCSEARCH_INDEX_NAME",
        "NEXT_PUBLIC_FORMBRICKS_PMF_FORM_ID",
        "NEXT_PUBLIC_FORMBRICKS_URL",
        "NEXT_PUBLIC_FORMBRICKS_COM_API_HOST",
        "NEXT_PUBLIC_FORMBRICKS_COM_ENVIRONMENT_ID",
        "NEXT_PUBLIC_FORMBRICKS_COM_DOCS_FEEDBACK_SURVEY_ID",
        "OPENTELEMETRY_LISTENER_URL",
        "NEXT_RUNTIME",
        "NEXTAUTH_SECRET",
        "NEXTAUTH_URL",
        "NODE_ENV",
        "OIDC_CLIENT_ID",
        "OIDC_CLIENT_SECRET",
        "OIDC_DISPLAY_NAME",
        "OIDC_ISSUER",
        "OIDC_SIGNING_ALGORITHM",
        "PASSWORD_RESET_DISABLED",
        "PLAYWRIGHT_CI",
        "DOCS_URL",
        "PRIVACY_URL",
        "RATE_LIMITING_DISABLED",
        "REDIS_URL",
        "S3_ACCESS_KEY",
        "S3_BUCKET_NAME",
        "S3_ENDPOINT_URL",
        "S3_FORCE_PATH_STYLE",
        "S3_REGION",
        "S3_SECRET_KEY",
        "SAML_DATABASE_URL",
        "SESSION_MAX_AGE",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_DSN",
        "SENTRY_ENVIRONMENT",
        "SLACK_CLIENT_ID",
        "SLACK_CLIENT_SECRET",
        "SMTP_HOST",
        "SMTP_PASSWORD",
        "SMTP_PORT",
        "SMTP_SECURE_ENABLED",
        "SMTP_USER",
        "SMTP_REJECT_UNAUTHORIZED_TLS",
        "SMTP_AUTHENTICATED",
        "STRAPI_API_KEY",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "SURVEYS_PACKAGE_MODE",
        "SURVEYS_PACKAGE_BUILD",
        "PUBLIC_URL",
        "TURNSTILE_SECRET_KEY",
        "TURNSTILE_SITE_KEY",
        "RECAPTCHA_SITE_KEY",
        "RECAPTCHA_SECRET_KEY",
        "TERMS_URL",
        "VERCEL",
        "VERCEL_URL",
        "VERSION",
        "WEBAPP_URL",
        "UNSPLASH_ACCESS_KEY",
        "PROMETHEUS_ENABLED",
        "PROMETHEUS_EXPORTER_PORT",
        "USER_MANAGEMENT_MINIMUM_ROLE",
        "GUEST_TOKEN_JWT_SECRET",
        "N8N_API_KEY",
        "N8N_BASE_URL",
        "N8N_WEBHOOK_BASE_URL",
        "NEXT_PUBLIC_SUPERSET_BASE_URL",
        "OIDC_ISSUER_URL",
        "OIDC_N8N_CLIENT_ID",
        "OIDC_N8N_CLIENT_SECRET",
        "OIDC_SUPERSET_CLIENT_ID",
        "OIDC_SUPERSET_CLIENT_SECRET",
        "SUPERSET_ADMIN_PASSWORD",
        "SUPERSET_ADMIN_USERNAME",
        "SUPERSET_BASE_URL",
        "MANAGEMENT_API_KEY"
      ],
      "outputs": ["dist/**", ".next/**"]
    },
    "build:dev": {
      "dependsOn": ["^build:dev"],
      "outputs": ["dist/**", ".next/**"]
    },
    "clean": {
      "cache": false,
      "outputs": []
    },
    "db:down": {
      "cache": false,
      "outputs": []
    },
    "db:migrate:deploy": {
      "cache": false,
      "outputs": []
    },
    "db:migrate:dev": {
      "cache": false,
      "outputs": []
    },
    "db:push": {
      "outputs": []
    },
    "db:seed": {
      "env": ["ALLOW_SEED"],
      "outputs": []
    },
    "db:setup": {
      "cache": false,
      "dependsOn": ["@hivecfm/logger#build", "@hivecfm/database#build"],
      "outputs": []
    },
    "db:start": {
      "cache": false
    },
    "db:up": {
      "cache": false,
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "generate": {
      "dependsOn": ["^generate"]
    },
    "go": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "start": {
      "outputs": []
    },
    "storybook": {
      "cache": false,
      "persistent": true
    },
    "storybook#storybook": {
      "dependsOn": ["@hivecfm/logger#build"]
    },
    "test": {
      "outputs": []
    },
    "test:coverage": {
      "outputs": []
    }
  },
  "ui": "stream"
}
