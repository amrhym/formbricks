########################################################################
# HiveCFM Environment Configuration
# Customer Feedback Management Platform
#
# Copy this file to .env and configure for your environment
# Generate secrets with: openssl rand -hex 32
########################################################################

###############################################################################
# REQUIRED - Core Application Settings
###############################################################################

# Application URL - set to your public-facing domain
WEBAPP_URL=http://localhost:3000

# NextAuth Configuration - must match WEBAPP_URL
NEXTAUTH_URL=http://localhost:3000

# Security Keys (REQUIRED - generate with: openssl rand -hex 32)
NEXTAUTH_SECRET=
ENCRYPTION_KEY=
CRON_SECRET=

###############################################################################
# DATABASE - PostgreSQL Configuration
###############################################################################

# PostgreSQL connection (internal Docker network)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/hivecfm?schema=public

# PostgreSQL password (used for postgres superuser)
POSTGRES_PASSWORD=postgres

###############################################################################
# CACHE - Redis/Valkey Configuration
###############################################################################

# Redis URL for caching and rate limiting
REDIS_URL=redis://redis:6379

###############################################################################
# EMAIL - SMTP Configuration
###############################################################################

# Email sender settings
MAIL_FROM=noreply@hivecfm.xcai.io
MAIL_FROM_NAME=HiveCFM

# SMTP Server settings
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE_ENABLED=0
SMTP_AUTHENTICATED=1

# Feature toggles (1=disabled, 0=enabled)
EMAIL_VERIFICATION_DISABLED=1
PASSWORD_RESET_DISABLED=1

###############################################################################
# HIVECFM-SPECIFIC - Genesys Cloud Integration
###############################################################################

# Genesys Cloud OAuth Credentials
# Get these from Genesys Cloud Admin > Integrations > OAuth
GENESYS_CLIENT_ID=
GENESYS_CLIENT_SECRET=

# Webhook signature verification secret
# Generate with: openssl rand -hex 32
GENESYS_WEBHOOK_SECRET=

# Genesys Cloud region
# Options: mypurecloud.com, mypurecloud.ie, mypurecloud.de,
#          mypurecloud.com.au, mypurecloud.jp, usw2.pure.cloud
GENESYS_REGION=mypurecloud.com

# Genesys API base URL (derived from region, override if needed)
# GENESYS_API_URL=https://api.mypurecloud.com

###############################################################################
# HIVECFM-SPECIFIC - Twilio SMS Gateway
###############################################################################

# Twilio Account Credentials
# Get these from Twilio Console > Account > API keys & tokens
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Twilio phone number for sending SMS (E.164 format: +1234567890)
TWILIO_PHONE_NUMBER=

# Twilio webhook verification (auto-generated if not set)
# TWILIO_WEBHOOK_SECRET=

###############################################################################
# ANALYTICS - Metabase Configuration
###############################################################################

# Metabase service port
METABASE_PORT=3001

# Metabase site URL (for embedding)
METABASE_URL=http://localhost:3001

# Metabase embedding secret key (generate with: openssl rand -hex 32)
METABASE_SECRET_KEY=

# Metabase premium token (if you have Metabase Pro/Enterprise)
METABASE_PREMIUM_TOKEN=

# Metabase database user password
METABASE_DB_PASSWORD=metabase

###############################################################################
# ANALYTICS - Apache Superset Configuration
###############################################################################

# Superset service port
SUPERSET_PORT=3002

# Superset secret key (generate with: openssl rand -hex 32)
SUPERSET_SECRET_KEY=

# Superset database user password
SUPERSET_DB_PASSWORD=superset

# Superset admin credentials (for initial setup)
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_ADMIN_EMAIL=admin@hivecfm.xcai.io

###############################################################################
# HIVECFM-SPECIFIC - Alert Configuration
###############################################################################

# Low CSAT alert threshold (1-5 scale)
ALERT_CSAT_THRESHOLD=3

# Alert email recipients (comma-separated)
ALERT_EMAIL_RECIPIENTS=

# Alert webhook URL (optional, for Slack/Teams integration)
ALERT_WEBHOOK_URL=

###############################################################################
# HIVECFM-SPECIFIC - Survey Throttling
###############################################################################

# Minimum time between surveys for same customer (hours)
SURVEY_THROTTLE_HOURS=24

# Maximum surveys per customer per month
SURVEY_MAX_PER_MONTH=4

###############################################################################
# OPTIONAL - OAuth Providers
###############################################################################

# GitHub OAuth
GITHUB_ID=
GITHUB_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Azure AD OAuth
AZUREAD_CLIENT_ID=
AZUREAD_CLIENT_SECRET=
AZUREAD_TENANT_ID=

# OpenID Connect
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_ISSUER=
OIDC_DISPLAY_NAME=

###############################################################################
# OPTIONAL - Third-Party Integrations
###############################################################################

# Notion Integration
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=

# Google Sheets Integration
GOOGLE_SHEETS_CLIENT_ID=
GOOGLE_SHEETS_CLIENT_SECRET=
GOOGLE_SHEETS_REDIRECT_URL=

# Airtable Integration
AIRTABLE_CLIENT_ID=

# Slack Integration
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

###############################################################################
# OPTIONAL - Storage (S3-compatible)
###############################################################################

# S3 Storage for file uploads
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=
S3_BUCKET_NAME=
S3_ENDPOINT_URL=
S3_FORCE_PATH_STYLE=0

###############################################################################
# OPTIONAL - Monitoring & Observability
###############################################################################

# Sentry Error Tracking
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=

# OpenTelemetry
OPENTELEMETRY_LISTENER_URL=

# Prometheus Metrics
PROMETHEUS_ENABLED=0
PROMETHEUS_EXPORTER_PORT=9090

# Audit Logging
AUDIT_LOG_ENABLED=0
AUDIT_LOG_GET_USER_IP=0

###############################################################################
# OPTIONAL - Legal & Compliance
###############################################################################

PRIVACY_URL=
TERMS_URL=
IMPRINT_URL=
IMPRINT_ADDRESS=

###############################################################################
# OPTIONAL - Bot Protection
###############################################################################

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google reCAPTCHA v3
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

###############################################################################
# DEVELOPMENT ONLY - Debug Settings
###############################################################################

# Log level (debug, info, warn, error, fatal)
LOG_LEVEL=info

# Rate limiting (disable for development)
RATE_LIMITING_DISABLED=0

# Node environment
NODE_ENV=production

###############################################################################
# DOCKER PORTS (for docker-compose)
###############################################################################

# HiveCFM Core port
HIVECFM_PORT=3000
